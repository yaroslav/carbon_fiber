#!/usr/bin/env ruby
# frozen_string_literal: true

# Worker subprocess: loads one scheduler target, runs one workload, prints the metric.
# Called by `bench` orchestrator. Not meant to be run directly.
#
# Usage: bench_one <target> <workload>
# Output: single floating-point number to stdout (the metric value)

require_relative "lib/bench"

target_id = ARGV[0] or abort("usage: bench_one <target> <workload>")
workload_id = ARGV[1] or abort("usage: bench_one <target> <workload>")

target = Bench::TARGETS.fetch(target_id) { abort("unknown target: #{target_id}") }
workload_def = Bench::WORKLOADS.fetch(workload_id) { abort("unknown workload: #{workload_id}") }

# Set up gem paths (Docker sets BENCH_GEM_HOME for per-target gem installs)
if (gem_home = ENV["BENCH_GEM_HOME"])
  target_home = File.join(gem_home, target_id)
  if Dir.exist?(target_home)
    ENV["GEM_HOME"] = target_home
    ENV["GEM_PATH"] = target_home
    Gem.clear_paths
  end
end

target[:require_proc].call
require_relative "lib/bench/workloads/#{workload_id}"

scheduler_class = Bench.constantize(target[:constant])
scheduler = scheduler_class.new
Fiber.set_scheduler(scheduler)

workload_class = Bench::Workloads.const_get(Bench.classify(workload_id))
Thread.handle_interrupt(Errno::EINTR => :never) do
  result = workload_class.new.call(scheduler, workload_def[:defaults])
  $stdout.puts result[workload_def[:metric]]
  $stdout.flush
  exit!(0)
end
