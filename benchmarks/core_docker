#!/usr/bin/env bash
# Run core benchmarks in a Docker container (io_uring).
#
# Usage:
#   benchmarks/core_docker -t carbon,async -w tcp_echo
#   benchmarks/core_docker -t carbon,async             # all workloads
#   benchmarks/core_docker --setup                     # install gems only
#
# All arguments are forwarded to `benchmarks/bench` inside the container.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

command -v docker >/dev/null 2>&1 || { echo "error: docker not found in PATH" >&2; exit 1; }

# Resolve symlinked tmp/upstream if present
UPSTREAM_MOUNT=()
if [[ -d "${ROOT}/tmp/upstream" ]]; then
  UPSTREAM="$(cd "${ROOT}/tmp/upstream" && pwd -P)"
  UPSTREAM_MOUNT=(-v "${UPSTREAM}:/workspace/tmp/upstream")
fi

docker build -t carbon-fiber-bench -f "${ROOT}/benchmarks/Dockerfile" "${ROOT}"

docker run --rm \
  --security-opt seccomp=unconfined \
  --ulimit memlock=-1 \
  -v "${ROOT}:/workspace" \
  "${UPSTREAM_MOUNT[@]}" \
  -w /workspace \
  -e BENCH_GEM_HOME=/workspace/tmp/linux_gems \
  -e RUBYOPT=--yjit \
  carbon-fiber-bench \
  bash -c 'bundle install --quiet && zig build -Doptimize=ReleaseFast && ruby ./benchmarks/bench --setup "$@" && ruby ./benchmarks/bench "$@"' -- "$@"
