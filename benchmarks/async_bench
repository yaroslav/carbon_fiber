#!/usr/bin/env ruby
# frozen_string_literal: true

# Async benchmark orchestrator: compares stock Async vs Async + CarbonFiber backend.
#
# Usage:
#   async_bench                                        # all targets, all workloads
#   async_bench -t stock,carbon -w task_churn            # specific
#   async_bench -r 3                                   # 3 runs, median
#
# Environment:
#   BENCH_GEM_HOME  — gem install root (default: benchmarks/.gems)
#   BENCH_TIMEOUT   — per-workload timeout in seconds (default: 30)

require "optparse"
require "timeout"
require_relative "lib/async_bench"

# --- CLI ---

targets = nil
workloads = nil
runs = 1
timeout = Integer(ENV.fetch("BENCH_TIMEOUT", 30))

OptionParser.new do |opts|
  opts.banner = "Usage: async_bench [options]"
  opts.on("-t", "--targets LIST", "Comma-separated target IDs") { |v| targets = v.split(",") }
  opts.on("-w", "--workloads LIST", "Comma-separated workload IDs") { |v| workloads = v.split(",") }
  opts.on("-r", "--runs N", Integer, "Number of runs per combo (default: 1)") { |v| runs = v }
  opts.on("--timeout N", Integer, "Per-workload timeout in seconds (default: 30)") { |v| timeout = v }
end.parse!

targets ||= AsyncBench::TARGETS.keys
# Default to the core workload set (backend-sensitive rows).  Workloads
# excluded from `CORE_WORKLOADS` are still runnable via `-w <name>` — see
# the comment next to `CORE_WORKLOADS` in `lib/async_bench.rb` for why
# they're not in the default.
workloads ||= AsyncBench::CORE_WORKLOADS.keys

# Validate against the full registry so opt-in workloads still work with `-w`.
targets.each { |t| AsyncBench::TARGETS.key?(t) or abort("unknown target: #{t}") }
workloads.each { |w| AsyncBench::WORKLOADS.key?(w) or abort("unknown workload: #{w}") }

# --- Run benchmarks ---

bench_one = File.join(__dir__, "async_bench_one")
gem_home = ENV["BENCH_GEM_HOME"] || File.join(__dir__, ".gems")
results = {}

warn "Async bench: #{targets.size} target(s) × #{workloads.size} workload(s) × #{runs} run(s)"
warn ""

runs.times do |run|
  $stderr.print "Run #{run + 1}/#{runs}: " if runs > 1
  targets.each do |t|
    workloads.each do |w|
      $stderr.print "#{t}/#{w} "

      rd, wr = IO.pipe
      env = {"BENCH_GEM_HOME" => gem_home}
      pid = Process.spawn(env, RbConfig.ruby, bench_one, t, w, out: wr, err: "/dev/null")
      wr.close

      begin
        Timeout.timeout(timeout) { Process.wait(pid) }
        if $?.success?
          value = rd.read.strip.to_f
          results[[t, w]] = [] unless results[[t, w]].is_a?(Array)
          results[[t, w]] << value
        else
          results[[t, w]] ||= :error
        end
      rescue Timeout::Error
        Process.kill("KILL", pid)
        Process.wait(pid)
        results[[t, w]] ||= :timeout
      ensure
        rd.close
      end
    end
  end
  $stderr.puts
end

# --- Compute medians ---

medians = {}
results.each do |key, val|
  medians[key] = if val.is_a?(Array) && !val.empty?
    sorted = val.sort
    sorted[sorted.size / 2]
  else
    val
  end
end

# --- Print markdown table ---

def format_cell(value, unit)
  return "error" if value == :error
  return "timeout" if value == :timeout

  "#{AsyncBench.fmt(value)} #{unit}"
end

def format_delta(baseline, current)
  return "" if !baseline.is_a?(Numeric) || !current.is_a?(Numeric) || baseline.zero?

  pct = ((current - baseline) / baseline.abs) * 100
  sign = (pct >= 0) ? "+" : ""
  "#{sign}#{format("%.1f", pct)}%"
end

best_per_workload = {}
workloads.each do |w|
  best_val = nil
  best_target = nil
  targets.each do |t|
    v = medians[[t, w]]
    next unless v.is_a?(Numeric) && v > 0
    if best_val.nil? || v > best_val
      best_val = v
      best_target = t
    end
  end
  best_per_workload[w] = best_target
end

show_delta = targets.size == 2
cells = {}
workloads.each do |w|
  unit = AsyncBench::WORKLOADS[w][:unit]
  targets.each do |t|
    cell = format_cell(medians[[t, w]], unit)
    cell = "**#{cell}**" if t == best_per_workload[w]
    cells[[t, w]] = cell
  end
end

workload_width = [8, *workloads.map(&:size)].max
col_widths = targets.map do |t|
  values = workloads.map { |w| cells[[t, w]] }
  [t.size, *values.map(&:size)].max
end
delta_width = 0

if show_delta
  deltas = workloads.map do |w|
    format_delta(medians[[targets[0], w]], medians[[targets[1], w]])
  end
  delta_width = [5, *deltas.map(&:size)].max
end

sep = "|-#{"-" * workload_width}-|"
targets.each_with_index { |_, i| sep += "-#{"-" * col_widths[i]}-|" }
sep += "-#{"-" * delta_width}-|" if show_delta

puts sep
header = "| #{format("%-#{workload_width}s", "workload")} |"
targets.each_with_index { |t, i| header += " #{t.rjust(col_widths[i])} |" }
header += " #{"delta".rjust(delta_width)} |" if show_delta
puts header
puts sep

workloads.each do |w|
  row = "| #{format("%-#{workload_width}s", w)} |"
  targets.each_with_index { |t, i| row += " #{cells[[t, w]].rjust(col_widths[i])} |" }

  if show_delta
    delta = format_delta(medians[[targets[0], w]], medians[[targets[1], w]])
    row += " #{delta.rjust(delta_width)} |"
  end

  puts row
end
puts sep
